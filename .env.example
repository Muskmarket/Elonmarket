# --- FRONTEND (Vite) ---
# Copy to .env and fill with your Supabase project values (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# --- BACKEND (Supabase Edge Functions) ---
# These should be set using 'supabase secrets set' command
# Example: npx supabase secrets set IFTTT_TIMEZONE_OFFSET=6

# Required for 'ifttt-webhook'
# IFTTT_TIMEZONE_OFFSET=6

# Required for 'detect-winner' (Vault integration)
# VAULT_URL=https://your-vault-server.com
# VAULT_PASSWORD=your-secure-password
# LOVABLE_API_KEY=your-api-key
